{
    "cmds-x": [
        ["огл", "@look"],
        ["инв", "@inv"],
        ["взять\\s+(\\S+)", "@get $1"],
        ["брос(?:ить|ь)?\\s+(\\S+)", "@drop $1"],
        ["(с|ю|з|в|сз|св|юз|юв|вв|вн)", "@walk $1"],
        ["сказ(?:ать)?\\s+(\\S.*)", "@say $1"],
        ["дать\\s+(\\S+)\\s+(\\S+)", "@give $1 $2"],
        ["готова?", "Banzai! :)"],
        ["у?щип(?:нуть)?\\s+(\\S+)", "@social $1 ущипнул#v"],
        ["(?:по)?целов(?:ать)?\\s+(\\S+)", "@social $1 поцеловал#v"],
        ["улыб(?:нуться)?\\s+(\\S+)", "@social $1 улыбнулся#v 2"],
        ["ха(?:\\-?ха)?", "@social !$u засмеялся#v: ха-ха-ха!"]
    ]
}
