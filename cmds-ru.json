{
    "cmds-x": [
        ["огл", "@look"],
        ["взять\\s+(\\S+)", "@get $1"],
        ["брос\\s+(\\S+)", "@drop $1"],
        ["(с|ю|з|в|сз|св|юз|юв|вв|вн)", "@walk $1"],
        ["сказ(?:ать)?\\s+(\\S.*)", "@say $1"],
        ["готова?", "Banzai! :)"],
        ["у?щип(?:нуть)?\\s+(\\S+)", "@social $1 ущипнул#v"],
        ["(?:по)?целов(?:ать)?\\s+(\\S+)", "@social $1 поцеловал#v"],
        ["ха(?:\\-?ха)?", "$u засмеялся#v: ха-ха-ха!"]
    ]
}
